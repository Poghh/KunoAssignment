PORT=3000

# Mail provider:
# - mock: no SMTP needed, always succeeds for demo/interview
# - smtp: real mail delivery via SMTP
MAIL_PROVIDER=mock

# SMTP configuration (required only when MAIL_PROVIDER=smtp)
# Outlook.com / Hotmail / Live => SMTP_HOST=smtp-mail.outlook.com
# Microsoft 365 mailbox      => SMTP_HOST=smtp.office365.com

SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-account@outlook.com
SMTP_PASS=your-app-password-or-mail-password

# Optional sender name/email. If omitted, SMTP_USER is used.
SMTP_FROM="Expense Tracker <your-account@outlook.com>"

# Optional: set false for local/dev if using self-signed certs
SMTP_TLS_REJECT_UNAUTHORIZED=true
